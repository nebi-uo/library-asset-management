<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.BorrowController"
            prefWidth="900" prefHeight="600"
            styleClass="root"
            stylesheets="@styles.css">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="10">
            <Label text="LibraTrack" styleClass="sidebar-title"/>
            <Label fx:id="welcomeLabel" styleClass="sidebar-user" text="Welcome,"/>

            <Separator/>

            <Button text="Dashboard" onAction="#goToDashboard" styleClass="nav-btn"/>
            <Button text="Borrow / Return" styleClass="nav-btn-active"/>

            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox styleClass="main-content" spacing="16">

            <Label text="Borrow &amp; Return Management" styleClass="page-title"/>

            <!-- Borrow Form -->
            <VBox styleClass="form-card" spacing="10">
                <Label text="Issue a Borrow" styleClass="card-title"/>
                <HBox spacing="10">
                    <TextField fx:id="borrowMemberIdField" promptText="Member ID"
                               styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="borrowItemIdField" promptText="Item ID"
                               styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Borrow" onAction="#handleBorrow" styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <!-- Return Form -->
            <VBox styleClass="form-card" spacing="10">
                <Label text="Process a Return" styleClass="card-title"/>
                <HBox spacing="10">
                    <TextField fx:id="returnRecordIdField" promptText="Borrow Record ID"
                               styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Return" onAction="#handleReturn" styleClass="btn-secondary"/>
                </HBox>
                <Label fx:id="fineLabel" text="" styleClass="fine-label"/>
            </VBox>

            <!-- Active Borrows Table -->
            <Label text="Active Borrows" styleClass="card-title"/>
            <TableView fx:id="borrowTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colRecordId" text="Record ID" prefWidth="90"/>
                    <TableColumn fx:id="colMemberId" text="Member ID" prefWidth="100"/>
                    <TableColumn fx:id="colItemTitle" text="Item Title" prefWidth="220"/>
                    <TableColumn fx:id="colBorrowDate" text="Borrow Date" prefWidth="130"/>
                    <TableColumn fx:id="colDueDate" text="Due Date" prefWidth="130"/>
                    <TableColumn fx:id="colBorrowStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>